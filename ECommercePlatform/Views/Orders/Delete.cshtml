@model ECommercePlatform.Models.Orders // Specifies the Orders model for the Delete view

@{
    // Starts a Razor code block for server-side initialization
    ViewData["Title"] = "Delete"; // Sets the browser page title to "Delete"
}

<h1>Delete</h1> <!-- Primary page heading -->

<h3>Are you sure you want to delete this?</h3> <!-- User confirmation message -->

<div>
    <!-- Container for order information -->
    <h4>Orders</h4> <!-- Sub-heading for the order entity -->
    <hr /> <!-- Horizontal line separator -->

    <dl class="row">
        <!-- Description list for order properties using Bootstrap grid -->
        <dt class="col-sm-2">
            <!-- Label column for the User ID -->
            @Html.DisplayNameFor(model => model.UserId) @* Displays the property name for UserId *@
        </dt>
        <dd class="col-sm-10">
            <!-- Data column for the User ID -->
            @Html.DisplayFor(model => model.UserId) @* Displays the actual value of UserId *@
        </dd>

        <dt class="col-sm-2">
            <!-- Label column for the Subtotal -->
            @Html.DisplayNameFor(model => model.Subtotal) @* Displays the property name for Subtotal *@
        </dt>
        <dd class="col-sm-10">
            <!-- Data column for the Subtotal -->
            @Html.DisplayFor(model => model.Subtotal) @* Displays the actual value of Subtotal *@
        </dd>

        <dt class="col-sm-2">
            <!-- Label column for the Delivery flag -->
            @Html.DisplayNameFor(model => model.Delivery) @* Displays the property name for Delivery *@
        </dt>
        <dd class="col-sm-10">
            <!-- Data column for the Delivery flag -->
            @Html.DisplayFor(model => model.Delivery) @* Displays the actual value of Delivery *@
        </dd>

        <dt class="col-sm-2">
            <!-- Label column for the Collection flag -->
            @Html.DisplayNameFor(model => model.Collection) @* Displays the property name for Collection *@
        </dt>
        <dd class="col-sm-10">
            <!-- Data column for the Collection flag -->
            @Html.DisplayFor(model => model.Collection) @* Displays the actual value of Collection *@
        </dd>

        <dt class="col-sm-2">
            <!-- Label column for the Delivery Type -->
            @Html.DisplayNameFor(model => model.DeliveryType) @* Displays the property name for DeliveryType *@
        </dt>
        <dd class="col-sm-10">
            <!-- Data column for the Delivery Type -->
            @Html.DisplayFor(model => model.DeliveryType) @* Displays the actual value of DeliveryType *@
        </dd>

        <dt class="col-sm-2">
            <!-- Label column for the Tracking Status -->
            @Html.DisplayNameFor(model => model.OrderTrackingStatus) @* Displays the property name for Tracking Status *@
        </dt>
        <dd class="col-sm-10">
            <!-- Data column for the Tracking Status -->
            @Html.DisplayFor(model => model.OrderTrackingStatus) @* Displays the actual value of Tracking Status *@
        </dd>

        <dt class="col-sm-2">
            <!-- Label column for the Collection Date -->
            @Html.DisplayNameFor(model => model.CollectionDate) @* Displays the property name for CollectionDate *@
        </dt>
        <dd class="col-sm-10">
            <!-- Data column for the Collection Date -->
            @Html.DisplayFor(model => model.CollectionDate) @* Displays the actual value of CollectionDate *@
        </dd>

        <dt class="col-sm-2">
            <!-- Label column for the Order Date -->
            @Html.DisplayNameFor(model => model.OrderDate) @* Displays the property name for OrderDate *@
        </dt>
        <dd class="col-sm-10">
            <!-- Data column for the Order Date -->
            @Html.DisplayFor(model => model.OrderDate) @* Displays the actual value of OrderDate *@
        </dd>
    </dl> <!-- Ends the description list -->

    <form asp-action="Delete">
        <!-- Form that submits the deletion request to the server -->
        <input type="hidden" asp-for="OrdersId" /> <!-- Hidden field to pass the Order ID to the Delete action -->
        <input type="submit" value="Delete" class="btn btn-danger" /> <!-- Button to confirm and execute deletion --> |
        <a asp-action="Index">Back to List</a> <!-- Link to cancel and return to the orders list -->
    </form> <!-- Ends the deletion form -->
</div> <!-- Ends the information container -->