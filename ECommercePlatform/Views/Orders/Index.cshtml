@model IEnumerable<ECommercePlatform.Models.Orders>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<div class="orders-container">

    @foreach (var item in Model)
    {
        <div class="order-card">

            <!-- TOP SECTION -->
            <div class="order-header">
                <h4>Order #@item.OrdersId</h4>
                <span class="status">@item.OrderTrackingStatus</span>
            </div>

            <!-- BODY -->
            <div class="order-body">

                <div class="order-row">
                    <span>Subtotal</span>
                    <span>£@item.Subtotal</span>
                </div>

                <div class="order-row">
                    <span>Delivery</span>
                    <span>£@item.Delivery</span>
                </div>

                <div class="order-row">
                    <span>Collection</span>
                    <span>@item.Collection</span>
                </div>

                <div class="order-row">
                    <span>Delivery Type</span>
                    <span>@item.DeliveryType</span>
                </div>

                <div class="order-row">
                    <span>Order Date</span>
                    <span>@item.OrderDate</span>
                </div>

                <div class="order-row">
                    <span>Collection Date</span>
                    <span>@item.CollectionDate</span>
                </div>

            </div>

            <!-- ACTIONS -->
            <div class="order-actions">
                <a asp-action="Edit" asp-route-id="@item.OrdersId">Edit</a>
                <a asp-action="Details" asp-route-id="@item.OrdersId">Details</a>
                <a asp-action="Delete" asp-route-id="@item.OrdersId">Delete</a>
            </div>

        </div>
    }

</div>