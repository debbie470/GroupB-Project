@model IEnumerable<ECommercePlatform.Models.Products>

<h1 class="section-title">Supplier Dashboard</h1>

<!-- STATS CARDS -->
<div class="dashboard-stats">

    <div class="stat-card">
        <h3>@Model.Count()</h3>
        <p>Total Products</p>
    </div>

    <div class="stat-card">
        <h3>@Model.Count(x => x.Stock <= 10)</h3>
        <p>Low Stock Products</p>
    </div>

    <div class="stat-card">
        <h3>@Model.Sum(x => x.Stock)</h3>
        <p>Total Stock Units</p>
    </div>

</div>

<!-- PRODUCTS SECTION -->
<h2 class="sub-title">Your Products</h2>

<div class="dashboard-table">

    <table>
        <thead>
            <tr>
                <th>Product</th>
                <th>Price</th>
                <th>Stock</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>£@item.Price</td>
                    <td>
                        <span class="stock-badge @(item.Stock <= 10 ? "low" : "ok")">
                            @item.Stock
                        </span>
                    </td>
                </tr>
            }
        </tbody>

    </table>

</div>

<!-- RECENT ORDERS -->
<h2 class="sub-title">Recent Orders</h2>

<div class="empty-box">
    <p>No recent orders found.</p>
</div>