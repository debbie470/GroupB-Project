            <!-- CATEGORY CARD: Bakery -->
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="category-card">
                    <div class="category-image" style="background-image: url('/images/Bread.jpg');">
                        <div class="category-overlay">
                            <span class="category-count">35+ Products</span>
                        </div>
                    </div>
                    <div class="category-content">
                        <h4>Bakery & Bread</h4>
                        <p>Artisan breads and baked goods made daily</p>
                        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-success">Shop Now →</a>
                    </div>
                </div>
            </div>
            <!-- CATEGORY CARD: Honey -->
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="category-card">
                    <div class="category-image" style="background-image: url('/images/honey.jpg');">
                        <div class="category-overlay">
                            <span class="category-count">25+ Products</span>
                        </div>
                    </div>
                    <div class="category-content">
                        <h4>Honey & Preserves</h4>
                        <p>Raw honey and homemade jams & preserves</p>
                        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-success">Shop Now →</a>
                    </div>
