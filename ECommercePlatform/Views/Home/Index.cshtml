                        <div class="category-overlay">
                            <span class="category-count">120+ Products</span>
                        </div>
                    </div>
                    <!-- Text content and shop button -->
                    <div class="category-content">
                        <h4>Fresh Vegetables</h4>
                        <p>Seasonal vegetables straight from local farms</p>
