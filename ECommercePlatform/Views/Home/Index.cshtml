@* Sets the page title to "Home" in the browser tab and layout *@
@{
    ViewData["Title"] = "Home";
}
<!-- Check if there is a success message stored in TemData-->
@if (TempData["SuccessMessage"] != null)
{
    <!-- If a message exists, display it inside a Bootstrap success alert box-->
    <div class="alert alert-success">
        <!-- Output the success message to the user-->
        @TempData["SuccessMessage"]
    </div>
}
<!-- HERO SECTION: The primary entry point and branding area of the homepage -->
<div class="hero">
    <!-- Centered container for standard grid alignment -->
    <div class="container">
        <!-- Content wrapper for vertical and horizontal spacing -->
        <div class="hero-content">
            <!-- Main welcome heading -->
            <h1>Welcome to Greenfield Local Hub</h1>
            <!-- Introductory paragraph explaining the platform mission -->
            <p>
                Your trusted local marketplace connecting farmers, producers, and the community.
                Fresh food, fair prices, and sustainable sourcing all in one place.
            </p>
        </div>
    </div>
</div>

<!-- FEATURES: 3D animated cards highlighting core platform benefits -->
<div class="container mt-5">
    <!-- Responsive row with centered text -->
    <div class="row text-center">
        <!-- CARD 1: Fresh & Local info -->
        <div class="col-md-4">
            <!-- Flip card container for 3D perspective -->
            <div class="flip-card">
                <!-- Inner container that rotates on hover -->
                <div class="flip-inner">
                    <!-- Front face of the card -->
                    <div class="flip-front">
                        <h4>🌿 Fresh & Local</h4>
                    </div>
                    <!-- Back face of the card containing detail -->
                    <div class="flip-back">
                        <p>Direct from farmers and local producers in your community.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- CARD 2: Fair Pricing info -->
        <div class="col-md-4">
            <!-- Flip card container -->
            <div class="flip-card">
                <!-- Inner rotating container -->
                <div class="flip-inner">
                    <!-- Front face -->
                    <div class="flip-front">
                        <h4>💰 Fair Pricing</h4>
                    </div>
                    <!-- Back face -->
                    <div class="flip-back">
                        <p>Support local businesses while getting affordable fresh produce.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- CARD 3: Delivery info -->
        <div class="col-md-4">
            <!-- Flip card container -->
            <div class="flip-card">
                <!-- Inner rotating container -->
                <div class="flip-inner">
                    <!-- Front face -->
                    <div class="flip-front">
                        <h4>🚚 Fast Delivery</h4>
                    </div>
                    <!-- Back face -->
                    <div class="flip-back">
                        <p>Quick and reliable delivery or collection options available.</p>
                    </div>
                </div>
            </div>
        </div>
        <!-- CARD 4: Sustainability info -->
        <div class="col-lg-3 col-md-6 mb-4">
            <!-- Flip card container -->
            <div class="flip-card">
                <!-- Inner rotating container -->
                <div class="flip-inner">
                    <!-- Front face with icon -->
                    <div class="flip-front">
                        <div class="feature-icon">🌍</div>
                        <h4>Eco-Friendly</h4>
                    </div>
                    <!-- Back face -->
                    <div class="flip-back">
                        <p>Sustainable packaging and reduced carbon footprint. We care for our planet as much as you do.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- FEATURED SECTION: Design and mission statement -->
<div class="container mt-5">
    <!-- Header for the section -->
    <h3 class="section-title">Why Choose Greenfield Local Hub?</h3>
    <!-- Descriptive text block about user experience and visual design -->
    <p class="section-text">
        These design choices create a professional, trustworthy, and user-friendly experience.
        A consistent colour scheme using natural greens and light neutrals creates a welcoming atmosphere
        that reflects local farming and fresh produce. Balanced contrast improves readability and reduces
        eye strain, while slightly rounded buttons provide a modern and intuitive interface.
        Interactive visuals help highlight featured products and producers, making the experience more engaging
        and easier to navigate.
    </p>
</div>

<!-- ACTION BUTTONS: Navigation to major site sections -->
<div>
    <!-- Button linking to the Product controller's Index view -->
    <a asp-controller="Products" asp-action="Index">Shop Now</a>
</div>
<!-- Button linking to the Supplier controller's Index view with green outline styling -->
<a asp-controller="Suppliers" asp-action="Index" class="btn btn-outline-success">
    View Farm →
</a>

<!-- HERO STATS: Large numerical highlights to build trust -->
<div class="hero-stats">
    <!-- Stat Item: Farmer count -->
    <div class="stat-item">
        <span class="stat-number">150+</span>
        <span class="stat-label">Local Farmers</span>
    </div>
    <!-- Stat Item: Product count -->
    <div class="stat-item">
        <span class="stat-number">5,000+</span>
        <span class="stat-label">Products</span>
    </div>
    <!-- Stat Item: Customer count -->
    <div class="stat-item">
        <span class="stat-number">25K+</span>
        <span class="stat-label">Happy Customers</span>
    </div>
</div>

<!-- ANNOUNCEMENT BAR: Promotes codes and shipping deals -->
<div class="announcement-bar">
    <!-- Inner container -->
    <div class="container">
        <!-- Promotional text with specific discount code -->
        <p>🎉 <strong>Free delivery</strong> on orders over £50 | Use code <strong>FRESH10</strong> for 10% off your first order!</p>
    </div>
</div>

<!-- PRODUCT CATEGORIES: Visual navigation for product types -->
<section class="categories-section">
    <!-- Container for spacing -->
    <div class="container">
        <!-- Centered header for category section -->
        <div class="section-header text-center">
            <span class="section-tag">Browse Our Selection</span>
            <h2>Shop by Category</h2>
            <p>Explore our wide range of locally sourced products</p>
