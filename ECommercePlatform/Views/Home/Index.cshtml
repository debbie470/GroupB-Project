            </div>
        </div>
    </div>
</section>

<!-- FEATURED PRODUCTS: Highlights individual items with pricing and ratings -->
<section class="featured-products">
    <div class="container">
        <!-- Section header -->
        <div class="section-header text-center">
            <span class="section-tag">Handpicked for You</span>
            <h2>Featured Products</h2>
            <p>Our most popular items this week</p>
        </div>
        <!-- Grid for product items -->
        <div class="row">
            <!-- PRODUCT 1: Tomatoes -->
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="product-card">
                    <!-- Marketing label -->
                    <div class="product-badge">Best Seller</div>
                    <!-- Image with hover action overlay -->
                    <div class="product-image">
                        <img src="/images/vine.jpg" alt="Organic Tomatoes">
                        <div class="product-actions">
                            <button class="btn-wishlist" title="Add to Wishlist">♡</button>
                            <button class="btn-quickview" title="Quick View">👁</button>
                        </div>
                    </div>
                    <!-- Product metadata and price -->
                    <div class="product-content">
                        <span class="product-category">Vegetables</span>
                        <h5>Organic Vine Tomatoes</h5>
                        <div class="product-rating">⭐⭐⭐⭐⭐ <span>(128 reviews)</span></div>
                        <div class="product-price">
                            <span class="current-price">£3.49</span>
                            <span class="original-price">£4.29</span>
                            <span class="discount">-19%</span>
                        </div>
                        <!-- Add to basket link -->
                        <a href="/Baskets" class="btn btn-success btn-block">Add to Cart</a>
                    </div>
                </div>
            </div>
            <!-- PRODUCT 2: Eggs -->
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="product-card">
                    <div class="product-badge new">New</div>
                    <div class="product-image">
                        <img src="/images/egg.jpg" alt="Free Range Eggs">
                        <div class="product-actions">
                            <button class="btn-wishlist" title="Add to Wishlist">♡</button>
                            <button class="btn-quickview" title="Quick View">👁</button>
                        </div>
                    </div>
                    <div class="product-content">
                        <span class="product-category">Dairy & Eggs</span>
                        <h5>Free Range Eggs (12 pack)</h5>
                        <div class="product-rating">⭐⭐⭐⭐⭐ <span>(94 reviews)</span></div>
                        <div class="product-price">
                            <span class="current-price">£4.99</span>
                        </div>
                        <a href="/Baskets" class="btn btn-success btn-block">Add to Cart</a>
                    </div>
                </div>
            </div>
            <!-- PRODUCT 3: Honey -->
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="product-card">
                    <div class="product-image">
                        <img src="/images/honey.jpg" alt="Local Honey">
                        <div class="product-actions">
                            <button class="btn-wishlist" title="Add to Wishlist">♡</button>
                            <button class="btn-quickview" title="Quick View">👁</button>
                        </div>
                    </div>
                    <div class="product-content">
                        <span class="product-category">Honey & Preserves</span>
                        <h5>Raw Wildflower Honey</h5>
                        <div class="product-rating">⭐⭐⭐⭐⭐ <span>(76 reviews)</span></div>
                        <div class="product-price">
                            <span class="current-price">£8.99</span>
                        </div>
                        <a href="/Baskets" class="btn btn-success btn-block">Add to Cart</a>
                    </div>
                </div>
            </div>
            <!-- PRODUCT 4: Sourdough -->
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="product-card">
                    <div class="product-badge sale">Sale</div>
                    <div class="product-image">
                        <img src="/images/Bread.jpg" alt="Sourdough Bread">
                        <div class="product-actions">
                            <button class="btn-wishlist" title="Add to Wishlist">♡</button>
                            <button class="btn-quickview" title="Quick View">👁</button>
                        </div>
                    </div>
                    <div class="product-content">
                        <span class="product-category">Bakery</span>
                        <h5>Artisan Sourdough Loaf</h5>
                        <div class="product-rating">⭐⭐⭐⭐⭐ <span>(112 reviews)</span></div>
                        <div class="product-price">
                            <span class="current-price">£4.49</span>
                            <span class="original-price">£5.49</span>
                            <span class="discount">-18%</span>
                        </div>
                        <a href="/Baskets" class="btn btn-success btn-block">Add to Cart</a>
                    </div>
                </div>
            </div>
        </div>
        <!-- Link to view full catalog -->
        <div class="text-center mt-4">
            <a href="/Products" class="btn btn-outline-success btn-lg">View All Products →</a>
        </div>
    </div>
</section>

<!-- HOW IT WORKS: Step-by-step process guide -->
<section class="how-it-works">
    <div class="container">
        <!-- Section header -->
        <div class="section-header text-center">
            <span class="section-tag">Simple & Easy</span>
            <h2>How It Works</h2>
            <p>Getting fresh local produce has never been easier</p>
        </div>
        <!-- Grid for 4 process steps -->
        <div class="row">
            <!-- Step 1: Browse -->
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="step-card">
                    <div class="step-number">1</div>
                    <div class="step-icon">🔍</div>
                    <h4>Browse Products</h4>
                    <p>Explore our wide selection of locally sourced produce and products from trusted farmers.</p>
                </div>
            </div>
            <!-- Step 2: Shopping -->
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="step-card">
                    <div class="step-number">2</div>
                    <div class="step-icon">🛒</div>
                    <h4>Add to Cart</h4>
                    <p>Select your favourite items and add them to your cart with just one click.</p>
                </div>
            </div>
            <!-- Step 3: Selection -->
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="step-card">
                    <div class="step-number">3</div>
                    <div class="step-icon">📅</div>
                    <h4>Choose Delivery</h4>
                    <p>Pick a convenient delivery slot or opt for collection at your nearest hub location.</p>
                </div>
            </div>
            <!-- Step 4: Fulfillment -->
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="step-card">
                    <div class="step-number">4</div>
                    <div class="step-icon">🎉</div>
                    <h4>Enjoy Fresh Food</h4>
                    <p>Receive your order and enjoy the freshest local produce delivered to your door.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ABOUT SECTION: Mission statement and company values -->
<section class="about-section">
    <div class="container">
        <!-- Centered alignment row -->
        <div class="row align-items-center">
            <!-- Left side: Collage of imagery -->
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="about-images">
                    <img src="/images/localfood.png" alt="Local Farm" class="about-img-main">
                    <img src="/images/vegetables.jpg" alt="Fresh Produce" class="about-img-secondary">
                    <div class="experience-badge">
                        <span class="years">6+</span>
                        <span class="text">Years Serving<br>Our Community</span>
                    </div>
                </div>
            </div>
            <!-- Right side: Narrative content -->
            <div class="col-lg-6">
                <div class="about-content">
                    <span class="section-tag">Our Story</span>
                    <h2>Why Choose Greenfield Local Hub?</h2>
                    <p class="lead">We believe in building a stronger community through sustainable, local food systems.</p>
                    <p>These design choices create a professional, trustworthy, and user-friendly experience...</p>
                    <p>Interactive visuals help highlight featured products and producers...</p>
                    <!-- List of core value features -->
                    <div class="about-features">
                        <div class="about-feature"><span class="check-icon">✓</span><span>100% locally sourced products</span></div>
                        <div class="about-feature"><span class="check-icon">✓</span><span>Supporting 150+ local farmers</span></div>
                        <div class="about-feature"><span class="check-icon">✓</span><span>Sustainable & eco-friendly packaging</span></div>
                        <div class="about-feature"><span class="check-icon">✓</span><span>Fair prices for farmers & customers</span></div>
                    </div>
                    <!-- Link to policy/about page -->
                    <a href="/Home/Privacy" class="btn btn-success btn-lg mt-3">Learn More About Us →</a>
                </div>
            </div>
        </div>
    </div>
</section>

