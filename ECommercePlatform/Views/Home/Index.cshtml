            <!-- CATEGORY CARD: Dairy -->
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="category-card">
                    <div class="category-image" style="background-image: url('/images/egg.jpg');">
                        <div class="category-overlay">
                            <span class="category-count">45+ Products</span>
                        </div>
                    </div>
                    <div class="category-content">
                        <h4>Dairy & Eggs</h4>
                        <p>Farm-fresh milk, cheese, and free-range eggs</p>
