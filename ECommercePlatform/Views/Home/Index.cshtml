                <div class="category-card">
                    <div class="category-image" style="background-image: url('/images/meat.jpg');">
                        <div class="category-overlay">
                            <span class="category-count">60+ Products</span>
                        </div>
                    </div>
                    <div class="category-content">
                        <h4>Meat & Poultry</h4>
                        <p>Ethically raised, locally sourced meats</p>
