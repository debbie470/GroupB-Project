                    </div>
                </div>
            </div>
            <!-- CATEGORY CARD: Fruits -->
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="category-card">
                    <div class="category-image" style="background-image: url('/images/fruits.jpg');">
                        <div class="category-overlay">
                            <span class="category-count">85+ Products</span>
                        </div>
                    </div>
