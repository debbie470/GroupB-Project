@model ECommercePlatform.Models.Suppliers // Specifies that the view expects a single Suppliers model object for deletion confirmation

@{
    // Start of a Razor code block for setting view-specific data
    ViewData["Title"] = "Delete"; // Sets the browser tab/page title to "Delete" via the ViewData dictionary
} 

<h1>Delete</h1> <!-- Main level 1 heading for the deletion page -->

<h3>Are you sure you want to delete this?</h3> <!-- A prompt asking the user for confirmation before proceeding with deletion -->

<div>
    <!-- Container for the supplier information that is about to be deleted -->

    <h4>Suppliers</h4> <!-- Sub-heading indicating the type of entity being reviewed -->

    <hr /> <!-- Horizontal line used as a visual separator -->

    <dl class="row">
        <!-- Starts a description list with Bootstrap grid classes for layout -->

        <dt class="col-sm-2">
            <!-- Defines the label column (2 units wide) for the User ID -->
            @Html.DisplayNameFor(model => model.UserId) <!-- HTML Helper that displays the property name for 'UserId' -->

        </dt> <!-- End of the User ID label -->

        <dd class="col-sm-10">
            <!-- Defines the value column (10 units wide) for the User ID -->
            @Html.DisplayFor(model => model.UserId) <!-- HTML Helper that displays the actual value of the 'UserId' -->

        </dd> <!-- End of the User ID value -->

        <dt class="col-sm-2">
            <!-- Defines the label column for the Supplier Name -->
            @Html.DisplayNameFor(model => model.SupplierName) <!-- HTML Helper that displays the property name for 'SupplierName' -->

        </dt> <!-- End of the Supplier Name label -->

        <dd class="col-sm-10">
            <!-- Defines the value column for the Supplier Name -->
            @Html.DisplayFor(model => model.SupplierName) <!-- HTML Helper that displays the actual value of the 'SupplierName' -->

        </dd> <!-- End of the Supplier Name value -->

        <dt class="col-sm-2">
            <!-- Defines the label column for the Supplier Email -->
            @Html.DisplayNameFor(model => model.SupplierEmail) <!-- HTML Helper that displays the property name for 'SupplierEmail' -->

        </dt> <!-- End of the Supplier Email label -->

        <dd class="col-sm-10">
            <!-- Defines the value column for the Supplier Email -->
            @Html.DisplayFor(model => model.SupplierEmail) <!-- HTML Helper that displays the actual value of the 'SupplierEmail' -->

        </dd> <!-- End of the Supplier Email value -->

        <dt class="col-sm-2">
            <!-- Defines the label column for the Supplier Information -->
            @Html.DisplayNameFor(model => model.SupplierInformation) <!-- HTML Helper that displays the property name for 'SupplierInformation' -->

        </dt> <!-- End of the Supplier Information label -->

        <dd class="col-sm-10">
            <!-- Defines the value column for the Supplier Information -->
            @Html.DisplayFor(model => model.SupplierInformation) <!-- HTML Helper that displays the actual value of the 'SupplierInformation' -->

        </dd> <!-- End of the Supplier Information value -->

    </dl> <!-- End of the description list -->

    <form asp-action="Delete">
        <!-- Form tag that will post to the 'Delete' action method in the controller upon submission -->

        <input type="hidden" asp-for="SuppliersId" /> <!-- Hidden input field to store the unique ID so the server knows which record to delete -->

        <input type="submit" value="Delete" class="btn btn-danger" /> | <!-- Submit button styled as a red 'danger' button to trigger the deletion -->

        <a asp-action="Index">Back to List</a> <!-- Link that redirects the user back to the main supplier list page if they cancel -->

    </form> <!-- End of the HTML form -->

</div> <!-- End of the main container div -->