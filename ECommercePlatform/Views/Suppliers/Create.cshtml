@model ECommercePlatform.Models.Suppliers // Specifies that the view expects a Suppliers model object to be passed in to create a new record

@{
    // Start of a Razor code block for setting view-specific metadata
    ViewData["Title"] = "Create"; // Sets the browser tab/page title to "Create" via the ViewData dictionary
} 

<h1>Create</h1> <!-- Main level 1 heading for the page -->

<h4>Suppliers</h4> <!-- Level 4 heading indicating the entity being created -->

<hr /> <!-- Horizontal line used as a visual separator -->

<div class="row">
    <!-- Bootstrap grid row to structure the form layout -->

    <div class="col-md-4">
        <!-- Bootstrap column spanning 4 out of 12 units for medium-sized screens -->

        <form asp-action="Create">
            <!-- Form tag that will post data to the 'Create' action method in the controller upon submission -->

            <div asp-validation-summary="ModelOnly" class="text-danger"></div> <!-- Displays a list of validation errors that apply to the model as a whole rather than specific fields -->

            <div class="form-group">
                <!-- Container for the Supplier Name input field -->

                <label asp-for="SupplierName" class="control-label"></label> <!-- Generates a label linked to the 'SupplierName' property of the model -->

                <input asp-for="SupplierName" class="form-control" /> <!-- Generates a text input styled with Bootstrap for entering the Supplier Name -->

                <span asp-validation-for="SupplierName" class="text-danger"></span> <!-- Placeholder for displaying validation error messages specific to 'SupplierName' -->

            </div> <!-- End of the Supplier Name group -->

            <div class="form-group">
                <!-- Container for the hidden User ID input -->
                @Html.HiddenFor(model => model.UserId) <!-- HTML Helper that creates a hidden input for 'UserId' to ensure it is sent with the form without showing it to the user -->

            </div> <!-- End of the hidden UserId group -->

            <div class="form-group">
                <!-- Container for the Supplier Email input field -->

                <label asp-for="SupplierEmail" class="control-label"></label> <!-- Generates a label linked to the 'SupplierEmail' property -->

                <input asp-for="SupplierEmail" class="form-control" /> <!-- Generates a text input for entering the Supplier Email address -->

                <span asp-validation-for="SupplierEmail" class="text-danger"></span> <!-- Placeholder for displaying validation error messages specific to 'SupplierEmail' -->

            </div> <!-- End of the Supplier Email group -->

            <div class="form-group">
                <!-- Container for the Supplier Information input field -->

                <label asp-for="SupplierInformation" class="control-label"></label> <!-- Generates a label linked to the 'SupplierInformation' property -->

                <input asp-for="SupplierInformation" class="form-control" /> <!-- Generates a text input for entering descriptive information about the supplier -->

                <span asp-validation-for="SupplierInformation" class="text-danger"></span> <!-- Placeholder for displaying validation error messages specific to 'SupplierInformation' -->

            </div> <!-- End of the Supplier Information group -->

            <div class="form-group">
                <!-- Container for the form submission button -->

                <input type="submit" value="Create" class="btn btn-primary" /> <!-- The button that triggers the form submission to save the new supplier -->

            </div> <!-- End of the submit button group -->

        </form> <!-- End of the HTML form -->

    </div> <!-- End of the column div -->

</div> <!-- End of the row div -->

<div>
    <!-- Container for navigation links -->

    <a asp-action="Index">Back to List</a> <!-- Link that redirects the user back to the main supplier list page -->

</div> <!-- End of the navigation div -->
@section Scripts {
     <!-- Defines a section for scripts that will be injected into the layout's script area -->
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    } <!-- Asynchronously renders the standard validation scripts for client-side form checking -->
} <!-- End of the Scripts section -->