@* Specifies the Basket model used to identify the record being deleted *@
@model ECommercePlatform.Models.Basket

@* Server-side block for setting page metadata *@
@{
    @* Sets the browser tab title for the deletion confirmation page *@
    ViewData["Title"] = "Delete";
}

@* Page main heading *@
<h1>Delete</h1>

@* Confirmation prompt for the user before performing the deletion *@
<h3>Are you sure you want to delete this?</h3>

@* Container for the basket's details *@
<div>
    @* Entity type identifier *@
    <h4>Basket</h4>
    @* Horizontal separator *@
    <hr />
    @* Description list using Bootstrap grid columns for labels and values *@
    <dl class="row">
        @* Label for the Status property *@
        <dt class="col-sm-2">
            @* Displays the metadata name of the Status field *@
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        @* Value for the Status property *@
        <dd class="col-sm-10">
            @* Renders the current boolean status value *@
            @Html.DisplayFor(model => model.Status)
        </dd>
        @* Label for the Creation Date property *@
        <dt class="col-sm-2">
            @* Displays the metadata name of the BasketCreatedAt field *@
            @Html.DisplayNameFor(model => model.BasketCreatedAt)
        </dt>
        @* Value for the Creation Date property *@
        <dd class="col-sm-10">
            @* Renders the recorded creation timestamp *@
            @Html.DisplayFor(model => model.BasketCreatedAt)
        </dd>
        @* Label for the User ID property *@
        <dt class="col-sm-2">
            @* Displays the metadata name of the UserId field *@
            @Html.DisplayNameFor(model => model.UserId)
        </dt>
        @* Value for the User ID property *@
        <dd class="col-sm-10">
            @* Renders the ID of the user associated with this basket *@
            @Html.DisplayFor(model => model.UserId)
        </dd>
    </dl>

    @* Form to submit the deletion request to the server *@
    <form asp-action="Delete">
        @* Hidden input to carry the primary key ID for the targeted record *@
        <input type="hidden" asp-for="BasketId" />
        @* Red button to trigger the final deletion POST request *@
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        @* Link to return to the index view without deleting *@
        <a asp-action="Index">Back to List</a>
    </form>
</div>