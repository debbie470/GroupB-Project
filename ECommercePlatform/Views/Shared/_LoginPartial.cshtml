@*
    Imports the namespace required for Identity services and user management
*@
@using Microsoft.AspNetCore.Identity 

@inject SignInManager<IdentityUser> SignInManager // Injects the SignInManager service to handle user authentication status checks

@inject UserManager<IdentityUser> UserManager // Injects the UserManager service to manage and retrieve user account details

<ul class="navbar-nav">
    <!-- Starts a Bootstrap unordered list for navigation items -->
    @if (SignInManager.IsSignedIn(User)) // Checks if the current user is authenticated/logged into the application

    { // Opening brace for the authenticated user logic block

        <li class="nav-item">
            <!-- List item container for the user's greeting link -->

            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">Hello @User.Identity?.Name!</a> <!-- Link to the user profile management page displaying the username -->

        </li> <!-- End of the greeting list item -->

        <li class="nav-item">
            <!-- List item container for the logout form -->

            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <!-- Form that posts to the logout handler and redirects to the home page -->

                <button type="submit" class="nav-link btn btn-link text-dark">Logout</button> <!-- Submit button styled as a link to trigger the logout process -->

            </form> <!-- End of the logout form -->

        </li> <!-- End of the logout list item -->
    } // Closing brace for the authenticated user block

    else // Block to execute if the user is not currently signed in

    { // Opening brace for the guest/anonymous user logic block

        <li class="nav-item">
            <!-- List item container for the registration link -->

            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">Register</a> <!-- Hyperlink leading to the account creation page -->

        </li> <!-- End of the register list item -->

        <li class="nav-item">
            <!-- List item container for the login link -->

            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a> <!-- Hyperlink leading to the user login page -->

        </li> <!-- End of the login list item -->
    } 

</ul> <!-- End of the navigation list -->