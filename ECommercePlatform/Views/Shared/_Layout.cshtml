<!-- Settings Button -->
<button type="button" class="btn btn-sm btn-outline-secondary" onclick="toggleSettings()">
    ⚙️ Settings
</button>

<!-- Settings Panel -->
<div id="settingsPanel" class="settings-panel">
    <h5>⚙️ Settings</h5>
    <hr />
    <button class="btn btn-sm btn-dark w-100 mb-2" onclick="toggleTheme()">🌙 Toggle Dark Mode</button>
    <button class="btn btn-sm btn-primary w-100 mb-2" onclick="speakPage()">🔊 Read Page</button>
    <button class="btn btn-sm btn-danger w-100" onclick="stopSpeaking()">⛔ Stop Speech</button>
    <h6>Font Size</h6>
    <button onclick="setFontSize('14px')">Small</button>
    <button onclick="setFontSize('16px')">Medium</button>
    <button onclick="setFontSize('18px')">Large</button>
</div>

<script>
    // ---------------- SETTINGS TOGGLE ----------------
    window.toggleSettings = function () {
        const panel = document.getElementById("settingsPanel");
        if (!panel) return;
        panel.classList.toggle("show");  // Toggle display of the settings panel
    };

    // ---------------- DARK MODE ----------------
    function applyTheme(isDark) {
        document.body.classList.toggle("dark-mode", isDark);
        localStorage.setItem("theme", isDark ? "dark" : "light");
    }

    window.toggleTheme = function () {
        const isDark = !document.body.classList.contains("dark-mode");
        applyTheme(isDark);
    };

    // Apply the saved theme on page load
    document.addEventListener("DOMContentLoaded", function () {
        const savedTheme = localStorage.getItem("theme");
        const isDark = savedTheme === "dark";
        applyTheme(isDark);
    });

    // ---------------- TEXT TO SPEECH ----------------
    window.speakPage = function () {
        window.speechSynthesis.cancel();

        const main = document.querySelector("main");
        const text = main ? main.innerText : document.body.innerText;

        const speech = new SpeechSynthesisUtterance(text);
        speech.rate = 1;
        speech.pitch = 1;
        speech.lang = "en-GB";

        window.speechSynthesis.speak(speech);
    };

    window.stopSpeaking = function () {
        window.speechSynthesis.cancel();
    };

    window.setFontSize = function (size) {
        console.log("Font size:", size); // debug

        document.documentElement.style.setProperty('--font-size', size);
        localStorage.setItem('fontSize', size);
    };

    // Apply saved font size on load
    document.addEventListener("DOMContentLoaded", function () {
        const savedSize = localStorage.getItem("fontSize");
        if (savedSize) {
            document.documentElement.style.setProperty('--font-size', savedSize);
        }
    });
</script>

<style>
    /* Example styles for the settings panel */
    .settings-panel {
        position: fixed;
        top: 70px;
        right: 20px;
        width: 220px;
        background: #ffffff;
        border-radius: 12px;
        padding: 15px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
        display: none;
        z-index: 9999;
    }

        .settings-panel.show {
            display: block;
        }

    /* Dark Mode styles */
    body.dark-mode {
        background: #121212;
        color: #f5f5f5;
    }

        /* Optional: Customize dark mode theme colors for specific elements */
        body.dark-mode .settings-panel {
            background: #333;
            color: #fff;
        }
</style>

