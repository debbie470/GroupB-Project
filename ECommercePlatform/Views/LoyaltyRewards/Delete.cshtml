@* Specifies the data model for the view to confirm the deletion of a Loyalty Reward record *@
@model ECommercePlatform.Models.LoyaltyRewards

@* Block for setting server-side page metadata *@
@{
    @* Sets the browser tab title for the deletion confirmation view *@
    ViewData["Title"] = "Delete";
}

@* Main heading for the deletion page *@
<h1>Delete</h1>

@* Confirmation message for the user *@
<h3>Are you sure you want to delete this?</h3>

@* Container for the loyalty reward record details *@
<div>
    @* Sub-heading identifying the entity type *@
    <h4>LoyaltyRewards</h4>

    @* Visual separator line *@
    <hr />

    @* Description list using Bootstrap grid classes for label/value alignment *@
    <dl class="row">
        @* Column for the User ID label *@
        <dt class="col-sm-2">
            @* Retrieves the display name attribute for the UserId property *@
            @Html.DisplayNameFor(model => model.UserId)
        </dt>
        @* Column for the User ID value *@
        <dd class="col-sm-10">
            @* Renders the specific User ID associated with these rewards *@
            @Html.DisplayFor(model => model.UserId)
        </dd>

        @* Column for the Points Balance label *@
        <dt class="col-sm-2">
            @* Retrieves the display name attribute for the PointsBalance property *@
            @Html.DisplayNameFor(model => model.PointsBalance)
        </dt>
        @* Column for the Points Balance value *@
        <dd class="col-sm-10">
            @* Renders the current points balance being deleted *@
            @Html.DisplayFor(model => model.PointsBalance)
        </dd>

        @* Column for the Tier Level label *@
        <dt class="col-sm-2">
            @* Retrieves the display name attribute for the TierLevel property *@
            @Html.DisplayNameFor(model => model.TierLevel)
        </dt>
        @* Column for the Tier Level value *@
        <dd class="col-sm-10">
            @* Renders the tier level (e.g., Gold, Silver) being deleted *@
            @Html.DisplayFor(model => model.TierLevel)
        </dd>

        @* Column for the History label *@
        <dt class="col-sm-2">
            @* Retrieves the display name attribute for the History property *@
            @Html.DisplayNameFor(model => model.History)
        </dt>
        @* Column for the History value *@
        <dd class="col-sm-10">
            @* Renders the historical activity logs *@
            @Html.DisplayFor(model => model.History)
        </dd>
    </dl>

    @* Form that posts to the 'Delete' action in the controller upon confirmation *@
    <form asp-action="Delete">
        @* Hidden input to pass the primary key ID back to the server for the deletion logic *@
        <input type="hidden" asp-for="LoyaltyRewardsId" />

        @* Red 'Delete' button to trigger the final removal of the record *@
        <input type="submit" value="Delete" class="btn btn-danger" /> |

        @* Link to cancel the action and return to the rewards list *@
        <a asp-action="Index">Back to List</a>
    </form>
</div>