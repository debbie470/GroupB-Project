@model IEnumerable<ECommercePlatform.Models.LoyaltyRewards>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
           
            <th>
                @Html.DisplayNameFor(model => model.PointsBalance)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TierLevel)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.History)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            
            <td>
                @Html.DisplayFor(modelItem => item.PointsBalance)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TierLevel)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.History)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.LoyaltyRewardsId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.LoyaltyRewardsId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.LoyaltyRewardsId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

<div class="loyalty-header text-center">

    <h2 class="title">🏆 Loyalty Rewards</h2>

    <p class="subtitle">
        Earn points, climb tiers, and unlock exclusive discounts
    </p>

    @{
        var nextTier = "Silver";
        var pointsNeeded = 100;

        var totalPoints = Model.Sum(x => x.PointsBalance);
    }

    <div class="progress-wrapper">

        <p class="progress-text">
            You have <strong>@totalPoints</strong> points.
            Only <strong>@pointsNeeded</strong> more to reach <strong>@nextTier</strong> 🎯
        </p>

        <div class="progress-bar-container">
            <div class="progress-bar-fill" style="width:@(totalPoints % 100)%"></div>
        </div>

    </div>

</div>

