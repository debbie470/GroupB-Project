@* Specifies the data model used for the deletion confirmation view *@
@model ECommercePlatform.Models.BasketProducts

@* Block for server-side code execution *@
@{
    @* Sets the browser tab title for this specific page *@
    ViewData["Title"] = "Delete";
}

@* Primary heading for the deletion page *@
<h1>Delete</h1>

@* Sub-heading asking for user confirmation before proceeding *@
<h3>Are you sure you want to delete this?</h3>

@* Container for the specific details of the record to be deleted *@
<div>
    @* Heading identifying the entity type *@
    <h4>BasketProducts</h4>

    @* Horizontal line for visual separation *@
    <hr />

    @* Grid-based description list for displaying model properties *@
    <dl class="row">
        @* Column for the label of the Quantity property *@
        <dt class="col-sm-2">
            @* Displays the metadata name for the Quantity field *@
            @Html.DisplayNameFor(model => model.Quantity)
        </dt>
        @* Column for the actual value of the Quantity property *@
        <dd class="col-sm-10">
            @* Renders the quantity value from the model *@
            @Html.DisplayFor(model => model.Quantity)
        </dd>

        @* Column for the label of the related Product *@
        <dt class="col-sm-2">
            @* Displays the metadata name for the Products navigation property *@
            @Html.DisplayNameFor(model => model.Products)
        </dt>
        @* Column for the value of the related Product *@
        <dd class="col-sm-10">
            @* Renders the ID of the product associated with this record *@
            @Html.DisplayFor(model => model.Products.ProductsId)
        </dd>

        @* Column for the label of the related Basket *@
        <dt class="col-sm-2">
            @* Displays the metadata name for the Basket navigation property *@
            @Html.DisplayNameFor(model => model.Basket)
        </dt>
        @* Column for the value of the related Basket *@
        <dd class="col-sm-10">
            @* Renders the ID of the basket associated with this record *@
            @Html.DisplayFor(model => model.Basket.BasketId)
        </dd>
    </dl>

    @* Form that sends the final deletion request to the server *@
    <form asp-action="Delete">
        @* Hidden input to pass the record ID to the controller action *@
        <input type="hidden" asp-for="BasketProductsId" />

        @* Red button to confirm and trigger the deletion *@
        <input type="submit" value="Delete" class="btn btn-danger" /> |

        @* Navigation link to cancel and return to the list view *@
        <a asp-action="Index">Back to List</a>
    </form>
</div>