@* Specifies the data model for this view to handle basket-product associations *@
@model ECommercePlatform.Models.BasketProducts

@* Block for setting server-side metadata *@
@{
    @* Sets the browser tab title for this page *@
    ViewData["Title"] = "Create";
}

@* Display the main page title *@
<h1>Create</h1>

@* Display the name of the entity being created *@
<h4>BasketProducts</h4>

@* Horizontal rule for visual separation *@
<hr />

@* Grid row container *@
<div class="row">
    @* Column spanning 4 out of 12 grid units on medium screens *@
    <div class="col-md-4">
        @* Form that submits data to the 'Create' action in the controller *@
        <form asp-action="Create">
            @* Container to display general model-level validation errors *@
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @* Container for the Basket selection field *@
            <div class="form-group">
                @* Label associated with the BasketId property *@
                <label asp-for="BasketId" class="control-label"></label>
                @* Dropdown list populated with Basket IDs from the ViewBag *@
                <select asp-for="BasketId" class="form-control" asp-items="ViewBag.BasketId"></select>
            </div>

            @* Container for the Product selection field *@
            <div class="form-group">
                @* Label associated with the ProductsId property *@
                <label asp-for="ProductsId" class="control-label"></label>
                @* Dropdown list populated with Product IDs from the ViewBag *@
                <select asp-for="ProductsId" class="form-control" asp-items="ViewBag.ProductsId"></select>
            </div>

            @* Container for the Quantity input field *@
            <div class="form-group">
                @* Label associated with the Quantity property *@
                <label asp-for="Quantity" class="control-label"></label>
                @* Numeric or text input bound to the Quantity property *@
                <input asp-for="Quantity" class="form-control" />
                @* Placeholder for field-specific validation error messages *@
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>

            @* Container for the form submission button *@
            <div class="form-group">
                @* Submit button to trigger the form POST request *@
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

@* Container for bottom navigation *@
<div>
    @* Hyperlink to navigate back to the main list view *@
    <a asp-action="Index">Back to List</a>
</div>

@* Scripts section to be rendered in the layout *@
@section Scripts {
    @* Renders the partial view containing jQuery validation logic *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}