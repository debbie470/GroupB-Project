@model IEnumerable<ECommercePlatform.Models.DeliveryInfo>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="delivery-table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.DeliveryType)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ScheduledDateTime)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Orders)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.DeliveryType)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ScheduledDateTime)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Orders.OrdersId)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.DeliveryInfoId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.DeliveryInfoId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.DeliveryInfoId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>



<div class="delivery-header">
    <h2>📦 Delivery Dashboard</h2>
    <p>Track your orders from dispatch to delivery</p>

    <div class="delivery-stats">
        <div class="stat-box">
            <h3>@Model.Count()</h3>
            <p>Total Deliveries</p>
        </div>

        <div class="stat-box">
            <h3>@Model.Count(x => x.Status == "Pending")</h3>
            <p>Pending</p>
        </div>

        <div class="stat-box">
            <h3>@Model.Count(x => x.Status == "Delivered")</h3>
            <p>Delivered</p>
        </div>
    </div>
</div>