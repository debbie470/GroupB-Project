@* Specifies the data model for the view to create new delivery information records *@
@model ECommercePlatform.Models.DeliveryInfo

@* Block for setting server-side page metadata *@
@{
    @* Sets the browser tab title to "Create" *@
    ViewData["Title"] = "Create";
}

@* Main heading of the creation page *@
<h1>Create</h1>

@* Sub-heading identifying the specific entity type being created *@
<h4>DeliveryInfo</h4>

@* Horizontal rule for visual separation *@
<hr />

@* Bootstrap grid row container *@
<div class="row">
    @* Column spanning 4 grid units for centered form alignment *@
    <div class="col-md-4">
        @* Form that sends data to the 'Create' action using the HTTP POST method *@
        <form asp-action="Create" method="post">
            @* Displays a list of validation errors that apply to the overall model *@
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @* Input group for selecting the associated Order ID *@
            <div class="form-group">
                @* Label associated with the OrdersId property *@
                <label asp-for="OrdersId" class="control-label"></label>
                @* Dropdown list populated with Order IDs passed from the controller via ViewBag *@
                <select asp-for="OrdersId" class="form-control" asp-items="ViewBag.OrdersId"></select>
            </div>

            @* Input group for the Delivery Type description *@
            <div class="form-group">
                @* Label associated with the DeliveryType property *@
                <label asp-for="DeliveryType" class="control-label"></label>
                @* Text input field bound to the DeliveryType property *@
                <input asp-for="DeliveryType" class="form-control" />
                @* Placeholder for field-specific validation error messages *@
                <span asp-validation-for="DeliveryType" class="text-danger"></span>
            </div>

            @* Input group for the Scheduled Date and Time *@
            <div class="form-group">
                @* Label associated with the ScheduledDateTime property *@
                <label asp-for="ScheduledDateTime" class="control-label"></label>
                @* Date-time picker input bound to the ScheduledDateTime property *@
                <input asp-for="ScheduledDateTime" class="form-control" />
                @* Placeholder for date-related validation errors *@
                <span asp-validation-for="ScheduledDateTime" class="text-danger"></span>
            </div>

            @* Input group for the current delivery Status *@
            <div class="form-group">
                @* Label associated with the Status property *@
                <label asp-for="Status" class="control-label"></label>
                @* Text input field bound to the Status property (e.g., Pending, Shipped) *@
                <input asp-for="Status" class="form-control" />
                @* Placeholder for status validation errors *@
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            @* Container for the submission action *@
            <div class="form-group">
                @* Button that triggers the form submission to save the record *@
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

@* Footer link section *@
<div>
    @* Navigation link to return to the delivery information list view *@
    <a asp-action="Index">Back to List</a>
</div>

@* Section for including client-side logic scripts *@
@section Scripts {
    @* Renders the partial view containing jQuery validation logic for the browser *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}