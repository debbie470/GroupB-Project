@* Specifies the data model for the view to update existing delivery information *@
@model ECommercePlatform.Models.DeliveryInfo

@* Block for setting server-side page metadata *@
@{
    @* Sets the browser tab title to "Edit" *@
    ViewData["Title"] = "Edit";
}

@* Main heading for the edit page *@
<h1>Edit</h1>

@* Sub-heading identifying the entity type being modified *@
<h4>DeliveryInfo</h4>

@* Horizontal rule for visual separation *@
<hr />

@* Bootstrap grid row container *@
<div class="row">
    @* Column spanning 4 grid units for centered form alignment *@
    <div class="col-md-4">
        @* Form that posts updated data to the 'Edit' action in the controller *@
        <form asp-action="Edit">
            @* Displays validation errors that apply to the model as a whole *@
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @* Hidden input to store and pass the primary key ID back to the server *@
            <input type="hidden" asp-for="DeliveryInfoId" />

            @* Input group for the associated Order ID *@
            <div class="form-group">
                @* Label associated with the OrdersId property *@
                <label asp-for="OrdersId" class="control-label"></label>
                @* Dropdown list populated with Order IDs from the ViewBag *@
                <select asp-for="OrdersId" class="form-control" asp-items="ViewBag.OrdersId"></select>
                @* Validation message placeholder for the OrdersId selection *@
                <span asp-validation-for="OrdersId" class="text-danger"></span>
            </div>

            @* Input group for the Delivery Type description *@
            <div class="form-group">
                @* Label associated with the DeliveryType property *@
                <label asp-for="DeliveryType" class="control-label"></label>
                @* Text input bound to the DeliveryType property *@
                <input asp-for="DeliveryType" class="form-control" />
                @* Validation message placeholder for the DeliveryType field *@
                <span asp-validation-for="DeliveryType" class="text-danger"></span>
            </div>

            @* Input group for the Scheduled Date and Time *@
            <div class="form-group">
                @* Label associated with the ScheduledDateTime property *@
                <label asp-for="ScheduledDateTime" class="control-label"></label>
                @* Date-time picker input bound to the ScheduledDateTime property *@
                <input asp-for="ScheduledDateTime" class="form-control" />
                @* Validation message placeholder for the date/time field *@
                <span asp-validation-for="ScheduledDateTime" class="text-danger"></span>
            </div>

            @* Input group for the delivery Status *@
            <div class="form-group">
                @* Label associated with the Status property *@
                <label asp-for="Status" class="control-label"></label>
                @* Text input bound to the current delivery Status *@
                <input asp-for="Status" class="form-control" />
                @* Validation message placeholder for the Status field *@
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            @* Container for the submission action *@
            <div class="form-group">
                @* Submit button to trigger the form POST request and save changes *@
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

@* Footer link section *@
<div>
    @* Navigation link to return to the delivery information list view *@
    <a asp-action="Index">Back to List</a>
</div>

@* Section for including client-side logic scripts *@
@section Scripts {
    @* Asynchronously renders the partial view containing jQuery validation logic *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}