@model IEnumerable<ECommercePlatform.Models.ProductTraceability>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Origin)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.BatchNumber)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.HarvestDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Certifications)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Products)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Origin)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.BatchNumber)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.HarvestDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Certifications)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Products.ProductsId)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ProductTraceabilityId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ProductTraceabilityId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ProductTraceabilityId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
