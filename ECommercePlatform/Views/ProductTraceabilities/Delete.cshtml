@model ECommercePlatform.Models.ProductTraceability // Specifies that this view is bound to a single ProductTraceability model object for deletion confirmation

@{
    // Starts a Razor code block for setting view-specific properties
    ViewData["Title"] = "Delete"; // Sets the browser tab and page title to "Delete" via the ViewData dictionary
} 

<h1>Delete</h1> <!-- Main level 1 heading for the deletion confirmation page -->

<h3>Are you sure you want to delete this?</h3> <!-- Confirmation message prompting the user to verify the destructive action -->
<div>
    <!-- Container for the details of the record intended for deletion -->
    <h4>ProductTraceability</h4> <!-- Level 4 heading identifying the entity type -->
    <hr /> <!-- Renders a horizontal line as a visual separator -->
    <dl class="row">
        <!-- Starts a description list with Bootstrap grid styling to display record attributes -->
        <dt class="col-sm-2">
            <!-- Term cell for the Origin property label -->
            @Html.DisplayNameFor(model => model.Origin) <!-- Displays the readable name/label for the 'Origin' property -->
        </dt> <!-- Ends the Origin label cell -->
        <dd class="col-sm-10">
            <!-- Description cell for the Origin value -->
            @Html.DisplayFor(model => model.Origin) <!-- Renders the actual value of the 'Origin' property -->
        </dd> <!-- Ends the Origin value cell -->
        <dt class="col-sm-2">
            <!-- Term cell for the Batch Number property label -->
            @Html.DisplayNameFor(model => model.BatchNumber) <!-- Displays the readable name/label for the 'BatchNumber' property -->
        </dt> <!-- Ends the Batch Number label cell -->
        <dd class="col-sm-10">
            <!-- Description cell for the Batch Number value -->
            @Html.DisplayFor(model => model.BatchNumber) <!-- Renders the actual value of the 'BatchNumber' property -->
        </dd> <!-- Ends the Batch Number value cell -->
        <dt class="col-sm-2">
            <!-- Term cell for the Harvest Date property label -->
            @Html.DisplayNameFor(model => model.HarvestDate) <!-- Displays the readable name/label for the 'HarvestDate' property -->
        </dt> <!-- Ends the Harvest Date label cell -->
        <dd class="col-sm-10">
            <!-- Description cell for the Harvest Date value -->
            @Html.DisplayFor(model => model.HarvestDate) <!-- Renders the actual value of the 'HarvestDate' property -->
        </dd> <!-- Ends the Harvest Date value cell -->
        <dt class="col-sm-2">
            <!-- Term cell for the Certifications property label -->
            @Html.DisplayNameFor(model => model.Certifications) <!-- Displays the readable name/label for the 'Certifications' property -->
        </dt> <!-- Ends the Certifications label cell -->
        <dd class="col-sm-10">
            <!-- Description cell for the Certifications value -->
            @Html.DisplayFor(model => model.Certifications) <!-- Renders the actual value of the 'Certifications' property -->
        </dd> <!-- Ends the Certifications value cell -->
        <dt class="col-sm-2">
            <!-- Term cell for the associated Product label -->
            @Html.DisplayNameFor(model => model.Products) <!-- Displays the readable name/label for the 'Products' navigation property -->
        </dt> <!-- Ends the Product label cell -->
        <dd class="col-sm-10">
            <!-- Description cell for the associated Product ID -->
            @Html.DisplayFor(model => model.Products.ProductsId) <!-- Renders the unique identifier of the related product -->
        </dd> <!-- Ends the Product ID value cell -->
    </dl> <!-- Ends the description list -->

    <form asp-action="Delete">
        <!-- Creates an HTML form that posts to the 'Delete' action to execute the removal -->
        <input type="hidden" asp-for="ProductTraceabilityId" /> <!-- Stores the primary key in a hidden field so the server knows which record to delete -->
        <input type="submit" value="Delete" class="btn btn-danger" /> <!-- The confirmation button that triggers the actual deletion, styled in red -->
        | <a asp-action="Index">Back to List</a> <!-- Hyperlink that allows the user to cancel and return to the main list -->
    </form> <!-- Ends the deletion form -->
</div> <!-- Ends the main container div -->