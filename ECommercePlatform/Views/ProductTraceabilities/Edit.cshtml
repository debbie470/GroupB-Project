@model ECommercePlatform.Models.ProductTraceability // Specifies that this view is bound to a single ProductTraceability model object for editing

@{
    // Starts a Razor code block for setting view-specific configurations
    ViewData["Title"] = "Edit"; // Sets the browser tab and page title to "Edit" via the ViewData dictionary
} 

<h1>Edit</h1> <!-- Main level 1 heading for the edit page -->

<h4>ProductTraceability</h4> <!-- Level 4 heading indicating the specific entity being modified -->
<hr /> <!-- Renders a horizontal line as a visual separator between the header and the form -->

<div class="row">
    <!-- Starts a Bootstrap grid row to organize the layout -->
    <div class="col-md-4">
        <!-- Defines a column that spans 4 out of 12 units on medium-sized screens or larger -->
        <form asp-action="Edit">
            <!-- Creates an HTML form that will post data back to the 'Edit' action method in the controller -->
            <div asp-validation-summary="ModelOnly" class="text-danger"></div> <!-- Container for displaying general validation errors that aren't tied to a specific field -->

            <input type="hidden" asp-for="ProductTraceabilityId" /> <!-- Includes a hidden input for the primary key so the server knows which record to update -->

            <div class="form-group">
                <!-- Groups the label and input for the Product selection -->
                <label asp-for="ProductsId" class="control-label"></label> <!-- Generates a label for the 'ProductsId' foreign key property -->
                <select asp-for="ProductsId" class="form-control" asp-items="ViewBag.ProductsId"></select> <!-- Renders a dropdown list populated with products from the ViewBag -->
                <span asp-validation-for="ProductsId" class="text-danger"></span> <!-- Placeholder for showing validation error messages related to product selection -->
            </div> <!-- End of the Product selection group -->

            <div class="form-group">
                <!-- Groups the label and input for the Origin field -->
                <label asp-for="Origin" class="control-label"></label> <!-- Generates a label for the 'Origin' property -->
                <input asp-for="Origin" class="form-control" /> <!-- Renders a text input for entering the origin of the product -->
                <span asp-validation-for="Origin" class="text-danger"></span> <!-- Placeholder for showing validation error messages related to the Origin field -->
            </div> <!-- End of the Origin group -->

            <div class="form-group">
                <!-- Groups the label and input for the Batch Number field -->
                <label asp-for="BatchNumber" class="control-label"></label> <!-- Generates a label for the 'BatchNumber' property -->
                <input asp-for="BatchNumber" class="form-control" /> <!-- Renders a text input for entering the product batch number -->
                <span asp-validation-for="BatchNumber" class="text-danger"></span> <!-- Placeholder for showing validation error messages related to the Batch Number -->
            </div> <!-- End of the Batch Number group -->

            <div class="form-group">
                <!-- Groups the label and input for the Harvest Date field -->
                <label asp-for="HarvestDate" class="control-label"></label> <!-- Generates a label for the 'HarvestDate' property -->
                <input asp-for="HarvestDate" class="form-control" /> <!-- Renders an input (typically a date picker) for the harvest date -->
                <span asp-validation-for="HarvestDate" class="text-danger"></span> <!-- Placeholder for showing validation error messages related to the Harvest Date -->
            </div> <!-- End of the Harvest Date group -->

            <div class="form-group">
                <!-- Groups the label and input for the Certifications field -->
                <label asp-for="Certifications" class="control-label"></label> <!-- Generates a label for the 'Certifications' property -->
                <input asp-for="Certifications" class="form-control" /> <!-- Renders a text input for entering certification details -->
                <span asp-validation-for="Certifications" class="text-danger"></span> <!-- Placeholder for showing validation error messages related to Certifications -->
            </div> <!-- End of the Certifications group -->

            <div class="form-group">
                <!-- Groups the form submission button -->
                <input type="submit" value="Save" class="btn btn-primary" /> <!-- The button that submits the form data to save the changes -->
            </div> <!-- End of the submit button group -->
        </form> <!-- Ends the HTML form -->
    </div> <!-- Ends the column div -->
</div> <!-- Ends the row div -->

<div>
    <!-- Container for navigation links -->
    <a asp-action="Index">Back to List</a> <!-- Hyperlink that redirects the user back to the main traceability list view -->
</div> <!-- Ends the navigation container -->
@section Scripts {
     <!-- Defines a section for JavaScript to be injected into the layout -->
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    } <!-- Asynchronously renders client-side validation scripts for real-time form checking -->
} <!-- Ends the Scripts section -->