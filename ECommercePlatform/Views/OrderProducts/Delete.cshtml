@* Specifies the data model for the view to confirm the deletion of a product from an order *@
@model ECommercePlatform.Models.OrderProducts

@* Block for setting server-side page metadata *@
@{
    @* Sets the browser tab title for the deletion confirmation view *@
    ViewData["Title"] = "Delete";
}

@* Main heading for the deletion page *@
<h1>Delete</h1>

@* Confirmation message for the user before permanent removal *@
<h3>Are you sure you want to delete this?</h3>

@* Container for the Order-Product relationship details *@
<div>
    @* Sub-heading identifying the entity type *@
    <h4>OrderProducts</h4>

    @* Visual separator line *@
    <hr />

    @* Description list using Bootstrap grid classes for label/value alignment *@
    <dl class="row">
        @* Column for the Quantity label *@
        <dt class="col-sm-2">
            @* Retrieves the display name attribute for the Quantity property *@
            @Html.DisplayNameFor(model => model.Quantity)
        </dt>
        @* Column for the Quantity value *@
        <dd class="col-sm-10">
            @* Renders the numerical quantity of the product in this order *@
            @Html.DisplayFor(model => model.Quantity)
        </dd>

        @* Column for the Product label *@
        <dt class="col-sm-2">
            @* Retrieves the display name attribute for the Products navigation property *@
            @Html.DisplayNameFor(model => model.Products)
        </dt>
        @* Column for the Product ID value *@
        <dd class="col-sm-10">
            @* Renders the ID of the linked product being removed from the order *@
            @Html.DisplayFor(model => model.Products.ProductsId)
        </dd>

        @* Column for the Order label *@
        <dt class="col-sm-2">
            @* Retrieves the display name attribute for the Orders navigation property *@
            @Html.DisplayNameFor(model => model.Orders)
        </dt>
        @* Column for the Order ID value *@
        <dd class="col-sm-10">
            @* Renders the ID of the associated order *@
            @Html.DisplayFor(model => model.Orders.OrdersId)
        </dd>
    </dl>

    @* Form that posts to the 'Delete' action in the controller upon final confirmation *@
    <form asp-action="Delete">
        @* Hidden input to pass the primary key ID back to the server to identify the record *@
        <input type="hidden" asp-for="OrderProductsId" />

        @* Red 'Delete' button to trigger the final removal from the database *@
        <input type="submit" value="Delete" class="btn btn-danger" /> |

        @* Link to cancel the deletion and return to the order-products list *@
        <a asp-action="Index">Back to List</a>
    </form>
</div>