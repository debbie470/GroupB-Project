@model IEnumerable<ECommercePlatform.Models.OrderProducts> // Specifies a collection of OrderProducts for the view

<h1 class="section-title">Order Products</h1> <!-- Main title for the order products section -->

<div class="order-product-container">
    <!-- Main wrapper for the list of order-product mapping cards -->
    @foreach (var item in Model)
    {
        // Iterates through each link between an order and a specific product
        <div class="order-product-card">
            <!-- Individual card representing a product within an order -->

            <div class="op-header">
                <!-- Header section of the card -->
                <h4>@item.Products.ProductName</h4> <!-- Displays the name of the product from the joined Products table -->
            </div> <!-- Ends card header -->

            <div class="op-body">
                <!-- Content area for product-specific order details -->
                <p><strong>Quantity:</strong> @item.Quantity</p> <!-- Displays the amount of this product ordered -->
                <p><strong>Order ID:</strong> #@item.OrdersId</p> <!-- Displays the unique ID of the parent order -->
            </div> <!-- Ends card body -->

            <div class="op-actions">
                <!-- Container for management links -->
                <a asp-action="Edit" asp-route-id="@item.OrderProductsId">Edit</a> <!-- Link to modify this specific order item -->
                <a asp-action="Details" asp-route-id="@item.OrderProductsId">Details</a> <!-- Link to view details for this order item -->
                <a asp-action="Delete" asp-route-id="@item.OrderProductsId">Delete</a> <!-- Link to remove this product from the order -->
            </div> <!-- Ends card actions -->

        </div> <!-- Ends the order-product card -->
    }

</div> <!-- Ends the main product container -->