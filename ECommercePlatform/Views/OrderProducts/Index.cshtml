@model IEnumerable<ECommercePlatform.Models.OrderProducts>

<h1 class="section-title">Order Products</h1>

<div class="order-product-container">

    @foreach (var item in Model)
    {
        <div class="order-product-card">

            <div class="op-header">
                <h4>@item.Products.ProductName</h4>
            </div>

            <div class="op-body">
                <p><strong>Quantity:</strong> @item.Quantity</p>
                <p><strong>Order ID:</strong> #@item.OrdersId</p>
            </div>

            <div class="op-actions">
                <a asp-action="Edit" asp-route-id="@item.OrderProductsId">Edit</a>
                <a asp-action="Details" asp-route-id="@item.OrderProductsId">Details</a>
                <a asp-action="Delete" asp-route-id="@item.OrderProductsId">Delete</a>
            </div>

        </div>
    }

</div>